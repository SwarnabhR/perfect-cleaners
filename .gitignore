# ─── Reference design system ─────────────────────────────────────────────────
# Static HTML prototypes — read-only, not part of the shipped product
/design-system

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
.next/
out/
dist/
build/
web-build/

# ─── Expo ─────────────────────────────────────────────────────────────────────
# Runtime cache (safe to delete at any time)
.expo/
.expo-shared/

# Native build directories generated by `expo prebuild`.
# This project uses managed workflow — do NOT commit these if/when they appear.
android/
ios/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Environment & credentials ────────────────────────────────────────────────
# Never commit credentials. Use .env.example / .env.local.example as templates.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Signing & certificates ───────────────────────────────────────────────────
*.jks
*.keystore
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*

# ─── Turborepo ────────────────────────────────────────────────────────────────
.turbo/

# ─── Claude Code ──────────────────────────────────────────────────────────────
# settings.json (shared project config) IS committed.
# settings.local.json contains personal overrides and must NOT be committed.
.claude/settings.local.json

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
