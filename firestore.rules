rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Each user can check their own admin status (read own /admins/{uid} doc).
    // Because the admins/{uid} rule allows `request.auth.uid == uid`, this
    // exists() call succeeds for self-checks without a circular dependency.
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Matches bookings created by authenticated users (uid) or the legacy
    // guest path (phone:<digits>) written by the web form before full auth.
    function isBookingCustomer() {
      return isSignedIn() && (
        resource.data.customerId    == request.auth.uid ||
        resource.data.customerPhone == request.auth.token.phone_number
      );
    }

    function isAssignedWorker() {
      return isSignedIn() && resource.data.workerId == request.auth.uid;
    }

    // ── Admins ────────────────────────────────────────────────────────────────
    // Each user may read their own admin doc so isAdmin() works via exists().
    // No client-side writes — managed via Firebase Console / Admin SDK only.
    match /admins/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Customers ─────────────────────────────────────────────────────────────
    match /customers/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /notifications/{notifId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin(); // mark read / clear
        allow create: if isAdmin();                    // written by Cloud Functions only
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Billing transactions — written by Cloud Functions (Admin SDK bypasses
      // rules); customers can read their own history but never write directly.
      match /transactions/{txId} {
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // ── Workers ───────────────────────────────────────────────────────────────
    // Only the worker themselves or an admin may read worker profiles.
    // (Worker name / rating shown to customers comes from denormalized fields
    //  on the booking doc — customers never query this collection directly.)
    match /workers/{workerId} {
      // isOwner: doc ID == UID (workers created via the API)
      // phone match: fallback for docs whose ID is not the UID (manually created)
      allow read:           if isOwner(workerId)
        || isAdmin()
        || (isSignedIn() && resource.data.phone == request.auth.token.phone_number);
      allow create, delete: if isAdmin();
      // Workers may update only operational/preference fields (isOnline, fcmToken, name, phone).
      // totalJobs (a stat) is written exclusively by the server-side API
      // (job-complete route) — never by the client SDK.
      allow update:         if isAdmin()
        || (isOwner(workerId)
            && !request.resource.data.diff(resource.data)
                  .affectedKeys()
                  .hasAny(['totalJobs', 'id', 'createdAt']));

      match /notifications/{notifId} {
        allow read:   if isOwner(workerId) || isAdmin();
        allow update: if isOwner(workerId) || isAdmin();
        allow create: if isAdmin();
        allow delete: if isOwner(workerId) || isAdmin();
      }

      // Worker-owned address book — used by the worker web profile page.
      match /addresses/{addressId} {
        allow read, write: if isOwner(workerId) || isAdmin();
      }
    }

    // ── Bookings ──────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Customers see their own bookings (matched by UID or phone number).
      // The phone-number path supports the web account page + mobile bookings
      // tab, which both query  where('customerPhone', '==', user.phoneNumber).
      allow read: if isBookingCustomer() || isAssignedWorker() || isAdmin();

      // Any signed-in user may create a booking (the booking flow requires auth).
      allow create: if isSignedIn();

      // Customers may cancel their own booking (status → cancelled only).
      // Workers may advance status and write checklist / photos / notes.
      // Admins may update anything.
      allow update: if isAdmin()
        || isAssignedWorker()
        || (isBookingCustomer()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'updatedAt'])
            && request.resource.data.status == 'cancelled');

      allow delete: if isAdmin();
    }

    // ── Services (catalogue) ──────────────────────────────────────────────────
    // Public read — shown on the marketing site without auth.
    match /services/{serviceId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Promotions ────────────────────────────────────────────────────────────
    // Any authenticated user can read (booking flow + offers tab).
    match /promotions/{promoId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Societies ─────────────────────────────────────────────────────────────
    // Any authenticated user can read (residents look up their society; the
    // mobile app and web portal need society details).  Only admins may write.
    match /societies/{societyId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Society cleaning programme ────────────────────────────────────────────

    // Customer enrolment records.
    // Customers read and lightly update their own record (time pref, skip dates).
    // Customers may create their own record during self-signup. Admins may
    // create one for anybody — the Pending Approvals "Approve" action writes
    // a record keyed by the *customer's* uid while signed in as the admin,
    // and the manual "Add customer" flow writes one for a resident who has
    // no uid at all — neither satisfies customerId == request.auth.uid.
    //
    // Claiming: a resident enrolled by phone before ever signing in gets
    // customerId = `admin_<phone>` (see customer-enrollments' "Add customer"
    // flow). The first time they sign in, account/cleaning looks this up by
    // phone and re-keys it to their real uid — allowed only when the
    // record's own customerPhone matches the caller's OWN verified phone
    // (from the auth token, not a client-supplied value) and only the
    // customerId/updatedAt fields change, so nobody can claim someone else's
    // enrollment or smuggle other field changes in through this path.
    match /customerSocietyRecords/{recordId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid)
        || (isSignedIn() && resource.data.customerPhone == request.auth.token.phone_number);
      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.customerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['permanentTime', 'preferredCleaningTime', 'preferredCleaningDays',
                          'skipDates', 'rescheduledSlots', 'updatedAt']))
        || (isSignedIn()
            && resource.data.customerId.matches('admin_.*')
            && resource.data.customerPhone == request.auth.token.phone_number
            && request.resource.data.customerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customerId', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Self-signup requests awaiting admin review.
    // Any signed-in customer may create a request for themselves; only admins
    // may read the queue and manage approvals.
    match /pendingApprovals/{approvalId} {
      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Tower billing configuration — admin-managed only.
    match /societyBillingConfig/{docId} {
      allow read, write: if isAdmin();
    }

    // Monthly billing records created by the billing cron (Admin SDK).
    // Admin-only on the client side.
    match /billingRecords/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Cleaning sessions ─────────────────────────────────────────────────────
    // Workers assigned to a session may read and update it (status, counts).
    // Two shapes of "assigned" exist: the legacy singular `workerId` (single-
    // worker sessions, e.g. /session/[id]) and the multi-worker `workerIds`
    // array (the admin Cleaning Schedule flow, 1-3+ workers per session) —
    // a worker must satisfy either to see their own assignment.
    // Admins have full access.  No client-side creates — admin/backend only.
    match /cleaningSessions/{sessionId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.workerId == request.auth.uid)
        || (isSignedIn() && ('workerIds' in resource.data) && resource.data.workerIds.hasAny([request.auth.uid]));
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.workerId == request.auth.uid)
        || (isSignedIn() && ('workerIds' in resource.data) && resource.data.workerIds.hasAny([request.auth.uid]));
      allow create, delete: if isAdmin();
    }

    // ── Cleaning logs ─────────────────────────────────────────────────────────
    // Workers may create logs for their own sessions.
    // Customers may read logs that belong to them (by customerId field).
    // Admins have full access.
    match /cleaningLogs/{logId} {
      allow read:   if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid)
        || (isSignedIn() && resource.data.workerId   == request.auth.uid);
      allow create: if isAdmin()
        || (isSignedIn()
          && request.resource.data.workerId   == request.auth.uid
          && request.resource.data.societyId   is string
          && request.resource.data.customerId  is string
          && request.resource.data.cleanedAt   != null);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Payment logs ──────────────────────────────────────────────────────────
    // Written by Cloud Functions and the admin billing page (Mark Paid action).
    // Customers never read this collection directly.
    match /paymentLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // ── Aggregate stats ───────────────────────────────────────────────────────
    // Counters (income, job counts) maintained by Cloud Functions and admin.
    match /stats/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Operator settings ─────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Support chat ──────────────────────────────────────────────────────────
    match /support/{userId}/messages/{msgId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Contact inquiries ─────────────────────────────────────────────────────
    // Public write so the contact form works without auth; admin-only read.
    match /contactInquiries/{docId} {
      allow create:      if request.resource.data.name    is string
                         && request.resource.data.message is string;
      allow read, write: if isAdmin();
    }

    // ── App waitlist ──────────────────────────────────────────────────────────
    match /appWaitlist/{docId} {
      allow create:      if request.resource.data.phone    is string
                         && request.resource.data.platform is string;
      allow read, write: if isAdmin();
    }

    // ── Notification history (sent by admin / approval flow) ─────────────────
    // Written by the Admin SDK via /api/notification/send; admin-only read.
    match /notifications/{docId} {
      allow read, write: if isAdmin();
    }

    // ── OTP verifications (server-side only) ──────────────────────────────────
    match /otpVerifications/{phone} {
      allow read, write: if false;
    }
  }
}
