rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Customers: own data only
    match /customers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bookings: customer or assigned worker can read; customer creates; either party updates
    match /bookings/{bookingId} {
      allow read: if request.auth != null &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.workerId  == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.workerId  == request.auth.uid);
    }

    // Workers: own profile only; location updates handled here
    match /workers/{workerId} {
      allow read, write: if request.auth != null && request.auth.uid == workerId;
    }

    // Services: public read; writes via Admin SDK / Cloud Functions only
    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // Promotions: public read; writes via Admin SDK / Cloud Functions only
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
