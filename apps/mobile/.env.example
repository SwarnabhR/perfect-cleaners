# Copy this file to .env and fill in your Firebase project values.
# Expo exposes variables prefixed with EXPO_PUBLIC_ to the JS bundle.
# Get these from: Firebase console → Project settings → Your apps → Web app → SDK setup

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
