# Copy this file to .env and fill in your values before running locally.
# For EAS builds, set secrets in: https://expo.dev/accounts/[account]/projects/perfect-cleaners/secrets
# All EXPO_PUBLIC_ vars are bundled into the app binary — do not put secrets here.

# ── Firebase (client-side) ────────────────────────────────────────────────────
# Firebase console → Project settings → Your apps → Web app → SDK setup
# Note: @react-native-firebase uses google-services.json (Android) and
#       GoogleService-Info.plist (iOS) for native config — these EXPO_PUBLIC_
#       vars are only used by packages/firebase for web/Expo Go compatibility.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=          # optional

# ── Razorpay (client-side — public key only) ──────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys → Key ID
# Development: rzp_test_…   Production: rzp_live_…
EXPO_PUBLIC_RAZORPAY_KEY_ID=
