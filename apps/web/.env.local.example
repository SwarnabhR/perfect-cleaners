# Copy this file to .env.local and fill in all values before running locally.
# On Vercel: set these in Project Settings → Environment Variables.
#
# ⚠️  FIREBASE_ADMIN_PRIVATE_KEY contains literal newlines.
#     In Vercel, paste the full JSON value as-is — Vercel handles multi-line secrets.
#     Locally, wrap in double-quotes and replace newlines with \n:
#     FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# ── Firebase (client-side — safe to expose) ───────────────────────────────────
# Firebase console → Project settings → Your apps → Web app → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=          # optional — GA4 measurement ID

# ── Firebase Admin SDK (server-side only — never expose) ──────────────────────
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── MSG91 OTP ─────────────────────────────────────────────────────────────────
# msg91.com → OTP → Widget  (widget ID + token are public/client-embedded)
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_WIDGET_TOKEN=
# msg91.com → API → Auth Key  (server-side only — used in /api/auth/verify-otp)
MSG91_AUTH_KEY=

# ── Razorpay ──────────────────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
# Development: rzp_test_…   Production: rzp_live_…
# Both vars are server-side only — never add a NEXT_PUBLIC_ version.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Vercel Cron ───────────────────────────────────────────────────────────────
# Vercel injects this automatically on Pro/Enterprise deployments.
# For local testing generate any random string: openssl rand -hex 32
CRON_SECRET=

# ── Site URL ──────────────────────────────────────────────────────────────────
# Canonical URL for metadata and sitemap. Defaults to https://perfectcleaners.in
NEXT_PUBLIC_BASE_URL=https://perfectcleaners.in
