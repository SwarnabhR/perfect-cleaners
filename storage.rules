rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Before/after photos — authenticated users can read; only registered
    // workers may write (verified via Firestore workers/{uid} existence).
    match /bookings/{bookingId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.exists(
                        /databases/(default)/documents/workers/$(request.auth.uid)
                      );
    }

    // Worker/customer avatars — public read, own write only
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
